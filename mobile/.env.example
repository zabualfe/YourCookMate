# iOS Simulator: http://127.0.0.1:8000 works when backend runs locally.
# Physical iPhone: use your Mac's LAN IP, e.g. http://192.168.1.42:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000

# Web OAuth client (used as webClientId hint for expo-auth-session)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# iOS OAuth client — required for Google sign-in on the mobile app.
# Create in Google Cloud Console → Credentials → OAuth client → iOS.
# Expo Go: bundle ID must be host.exp.Exponent (set EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID_EXPO_GO).
# Dev/standalone build: bundle ID com.yourcookmate.app (EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID_EXPO_GO=
