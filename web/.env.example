# Optional — OAuth client IDs (must match backend GOOGLE_CLIENT_ID / APPLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=

# Production API URL (required on Vercel). Leave unset locally — Vite proxies /api to localhost:8000.
# Example: https://api.yourcookmate.com
VITE_API_URL=

# Optional — password-protect the site on Vercel (Edge Middleware). Any username works; only the password is checked.
# Leave unset for a public site. Does not affect local `npm run dev`.
SITE_PASSWORD=
