OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Comma-separated browser origins. FRONTEND_URL is always allowed automatically.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local dev (default):
# DATABASE_URL=sqlite:///./yourcookmate.db
#
# Supabase (Project Settings → Database → Connect → Session pooler, port 5432):
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
# Use Session pooler (port 5432), not Transaction pooler (6543), for SQLAlchemy.
DATABASE_URL=sqlite:///./yourcookmate.db

# Public API URL (Render/Railway/etc.) — used in emails, OAuth callbacks, upload URLs
API_BASE_URL=http://127.0.0.1:8000
JWT_SECRET=dev-change-me-in-production

# Optional OAuth (leave blank to hide buttons in the UI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
APPLE_CLIENT_ID=

# Frontend URL (used in verification email links)
FRONTEND_URL=http://localhost:5173

# Instacart — set INSTACART_ENABLED=true after you have Developer Platform access
# Apply: https://instacart.com/company/business/developers
INSTACART_ENABLED=false
INSTACART_API_KEY=
INSTACART_API_BASE=https://connect.dev.instacart.tools
INSTACART_LINK_EXPIRES_DAYS=30

# Instacart Connect OAuth (account linking — separate Instacart Connect partner program)
INSTACART_CONNECT_CLIENT_ID=
INSTACART_CONNECT_CLIENT_SECRET=
INSTACART_CONNECT_API_BASE=https://connect.dev.instacart.tools
# Authorization URL provided by Instacart when account_linking scope is enabled
INSTACART_CONNECT_AUTHORIZE_URL=

# Resend (recommended): https://resend.com/api-keys
RESEND_API_KEY=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_FROM=noreply@yourcookmate.com
SMTP_USE_TLS=false
SMTP_USE_SSL=false
