{
  "name": "your-cook-mate",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.js",
    "db:up": "docker compose up -d postgres",
    "db:init": "node scripts/init-db.js",
    "test:smtp": "node scripts/test-smtp.js",
    "dev": "(docker compose up -d postgres 2>/dev/null || true) && sleep 2 && concurrently -n backend,web -c green,cyan \"node scripts/run-backend.js\" \"npm run dev --prefix web\"",
    "dev:backend": "node scripts/run-backend.js",
    "dev:web": "npm run dev --prefix web",
    "dev:mobile": "npm run start --prefix mobile",
    "ios": "npm run ios --prefix mobile",
    "export:cookies": "bash scripts/export-ytdlp-cookies.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
